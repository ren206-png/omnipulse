# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/omnipulse

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# URLs (no trailing slash)
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
APP_URL=http://localhost:3000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://getomnipulse.com,https://www.getomnipulse.com

# ─── Redis (BullMQ job queue) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=OmniPulse <noreply@getomnipulse.com>

# ─── AI (Anthropic) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# AI feature daily caps per user (default 50 each; 0 = unlimited)
AI_MULTIPLIER_DAILY_LIMIT=50
AI_VISION_DAILY_LIMIT=50

# ─── Payments (Stripe) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_AGENCY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# ─── Social OAuth ────────────────────────────────────────────────────────────
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

X_CLIENT_ID=
X_CLIENT_SECRET=

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://api.yourdomain.com/api/v1/social-accounts/oauth/callback
LINKEDIN_API_VERSION=202504

# ─── Token Encryption ────────────────────────────────────────────────────────
# 64-char hex string (32 bytes). Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ─── Social Publishing (Ayrshare) ────────────────────────────────────────────
AYRSHARE_API_KEY=
AYRSHARE_X_API_KEY=
AYRSHARE_X_API_SECRET=

# ─── Web (Next.js) ───────────────────────────────────────────────────────────
# Set these in apps/web/.env.local or in Vercel dashboard
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEV_MODE=true

# ─── Mobile (Expo) ───────────────────────────────────────────────────────────
# Set in apps/mobile/.env or in EAS Secrets
EXPO_PUBLIC_API_URL=http://localhost:4000
